{
    "name": "M3_Kart",
    "version": "1.0.0",
    "main": "main.js",
    "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.m3.kart",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "app_icon.ico"
    },
    "asar": true
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
  